#!/bin/bash

# newproject - SSH to server, create a new project with standard infrastructure, and start codex
# Uses first server from ~/.workon_hosts by default, or specify with --server

set -e

SCRIPT_SOURCE="${BASH_SOURCE[0]}"
while [ -h "$SCRIPT_SOURCE" ]; do
    SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT_SOURCE")" >/dev/null 2>&1 && pwd)"
    SCRIPT_SOURCE="$(readlink "$SCRIPT_SOURCE")"
    [[ "$SCRIPT_SOURCE" != /* ]] && SCRIPT_SOURCE="$SCRIPT_DIR/$SCRIPT_SOURCE"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT_SOURCE")" >/dev/null 2>&1 && pwd)"
# shellcheck source=workon-common
. "$SCRIPT_DIR/workon-common"

if ! SSH_HOSTS_OUTPUT=$(workon_get_hosts); then
    exit 1
fi

# Convert space-separated output to array
read -ra SSH_HOSTS <<< "$SSH_HOSTS_OUTPUT"

if [ ${#SSH_HOSTS[@]} -eq 0 ]; then
    echo "Error: No running EC2 instances found with Workon=true tag"
    echo ""
    echo "Tag your instances with: aws ec2 create-tags --resources <instance-id> --tags Key=Workon,Value=true"
    exit 1
fi

# Parse arguments: newproject [server] <project>
SSH_HOST=""
PROJECT_NAME=""

if [ $# -eq 2 ]; then
    # Two args: first is server prefix, second is project name
    SERVER_PREFIX="$1"
    PROJECT_NAME="$2"

    # Find matching server (case-insensitive prefix match)
    shopt -s nocasematch
    for host in "${SSH_HOSTS[@]}"; do
        if [[ "$host" == "${SERVER_PREFIX}"* ]]; then
            if [ -n "$SSH_HOST" ]; then
                echo "Error: Server prefix '$SERVER_PREFIX' matches multiple servers: $SSH_HOST, $host"
                exit 1
            fi
            SSH_HOST="$host"
        fi
    done
    shopt -u nocasematch

    if [ -z "$SSH_HOST" ]; then
        echo "Error: No server matches prefix '$SERVER_PREFIX'"
        echo ""
        echo "Available servers:"
        for host in "${SSH_HOSTS[@]}"; do
            echo "  - $host"
        done
        exit 1
    fi
elif [ $# -eq 1 ]; then
    PROJECT_NAME="$1"
    SSH_HOST="${SSH_HOSTS[0]}"
fi

if [ -z "$PROJECT_NAME" ]; then
    echo "Usage: newproject <project_name>"
    echo "       newproject <server> <project_name>"
    echo "Example: newproject myapp"
    echo "Example: newproject finance open-ended"
    echo ""
    echo "If a server is specified, it matches by prefix (case-insensitive)."
    echo "If no server is specified, uses the first available server."
    echo ""
    echo "Creates a new project with standard infrastructure:"
    echo "  - App user: app_<name>"
    echo "  - Code directory: ~/apps/<name>/"
    echo "  - Data directory: /home/app_<name>/data/"
    echo "  - VERSION file initialized to 1.0.0"
    echo ""
    echo "Available servers:"
    for host in "${SSH_HOSTS[@]}"; do
        if [ "$host" = "${SSH_HOSTS[0]}" ]; then
            echo "  - $host (default)"
        else
            echo "  - $host"
        fi
    done
    exit 1
fi

# Validate project name (lowercase, alphanumeric, underscores, hyphens)
if [[ ! "$PROJECT_NAME" =~ ^[a-z0-9_-]+$ ]]; then
    echo "Error: Project name must be lowercase alphanumeric with underscores/hyphens only"
    echo "Got: $PROJECT_NAME"
    exit 1
fi

echo "Creating project '$PROJECT_NAME' on $SSH_HOST"

# Set iTerm2 tab title
echo -ne "\033]0;${PROJECT_NAME}\007"

workon_configure_ssh
SSH_OPTS="$WORKON_SSH_OPTS"

# SSH and run remote commands
ssh -t $SSH_OPTS "$SSH_HOST" bash -c "'
    set -e

    # Load nvm to get the correct node/codex
    export NVM_DIR=\"\$HOME/.nvm\"
    [ -s \"\$NVM_DIR/nvm.sh\" ] && . \"\$NVM_DIR/nvm.sh\"

    PROJECT_NAME=\"$PROJECT_NAME\"
    PROJECT_DIR=\"\$HOME/apps/\$PROJECT_NAME\"
    APP_USER=\"app_\$PROJECT_NAME\"

    # Check if project already exists
    if [ -d \"\$PROJECT_DIR\" ]; then
        echo \"Error: Project directory already exists: \$PROJECT_DIR\"
        echo \"Use workon to open an existing project.\"
        exit 1
    fi

    echo \"Creating new project: \$PROJECT_NAME\"
    echo \"========================================\"

    # 1. Create app user (for runtime isolation)
    if id \"\$APP_USER\" &>/dev/null; then
        echo \"App user \$APP_USER already exists\"
    else
        echo \"Creating app user: \$APP_USER\"
        sudo useradd -m -s /usr/sbin/nologin \"\$APP_USER\"
    fi

    # 2. Create data directory
    DATA_DIR=\"/home/\$APP_USER/data\"
    if [ ! -d \"\$DATA_DIR\" ]; then
        echo \"Creating data directory: \$DATA_DIR\"
        sudo -u \"\$APP_USER\" mkdir -p \"\$DATA_DIR\"
    fi

    # 3. Create code directory
    echo \"Creating code directory: \$PROJECT_DIR\"
    mkdir -p \"\$PROJECT_DIR\"

    # 4. Initialize VERSION file
    echo \"1.0.0\" > \"\$PROJECT_DIR/VERSION\"
    echo \"Initialized VERSION to 1.0.0\"

    echo \"========================================\"
    echo \"Project created successfully!\"
    echo \"  Code: \$PROJECT_DIR\"
    echo \"  Data: \$DATA_DIR\"
    echo \"  User: \$APP_USER\"
    echo \"========================================\"
'"

# Now start working on the project
exec "$SCRIPT_DIR/codexl" "${SSH_HOST}/${PROJECT_NAME}"
